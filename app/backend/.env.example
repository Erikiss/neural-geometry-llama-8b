# REQUIRED: OpenAI API Key for prompt generation (GPT-4o-mini)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OPTIONAL: HuggingFace API Token for model access
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# OPTIONAL: NDIF API Key for nnsight library (neural network analysis)
NDIF_API_KEY=7522e81c-...

# OPTIONAL: CORS origin for frontend (set to your frontend URL in production)
CORS_ORIGIN=https://your-app.vercel.app
